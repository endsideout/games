# Firebase configuration for game tracking
# Copy this file to .env and fill in your Firebase project values
# Get these from: Firebase Console → Project Settings → Your apps

# App environment flag
# Use "production" for prod deploy, "staging" for peer-testing deploy
VITE_APP_ENV=production

# Staging-only controls
# Comma-separated allowlist for staging dashboard logins
VITE_STAGING_ADMIN_ALLOWLIST=
# Production Firebase project ID used for safety mismatch checks in staging
VITE_PRODUCTION_FIREBASE_PROJECT_ID=
# Shareable staging base URL used by helper docs/scripts
VITE_STAGING_BASE_URL=https://staging-endsideoutgames.netlify.app

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=
